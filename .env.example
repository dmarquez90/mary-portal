# Copy to .env.local and fill in your Supabase project values
# (Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — NOT required by this app at runtime. Privileged operations
# (agent creation) run inside Supabase Edge Functions, where the service
# role key is injected automatically by Supabase. Never expose this key
# to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — public base URL used for agents' referral links
# (falls back to the browser origin if unset).
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
